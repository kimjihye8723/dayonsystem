# Database Connection
DB_HOST=your_db_host
DB_USER=your_db_user
DB_PASS=your_db_pass
DB_NAME=your_db_name

# CCTV Default Auth
CCTV_USER=admin
CCTV_PASSWORD=your_cctv_password

# Polling interval (ms) - how often to poll each CCTV sensor
POLLING_INTERVAL=60000
# List refresh interval (ms) - how often to refresh the CCTV list from DB
LIST_REFRESH_INTERVAL=300000
